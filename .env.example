# --- Core ---
JWT_SECRET=
OPENAI_API_KEY=
ENVIRONMENT=development

# --- Public URLs (hosted deploy) ---
# Browser workspace / checkout return pages (Stripe success/cancel, Connect UX redirects to ?stripe=…).
# Preferred name:
# FRONTEND_PUBLIC_ORIGIN=https://your-workspace.example.com
# Legacy alias (same meaning):
# FRONTEND_URL=http://127.0.0.1:8001
FRONTEND_PUBLIC_ORIGIN=
FRONTEND_URL=

# Public base URL of this FastAPI app (must match where the API is reachable).
# Stripe Connect redirect defaults to {API_PUBLIC_ORIGIN}/integrations/stripe/callback
# Preferred name:
# API_PUBLIC_ORIGIN=https://your-api.up.railway.app
# Legacy alias:
# APP_ORIGIN=
API_PUBLIC_ORIGIN=
APP_ORIGIN=

# Local-only override if you run API on a non-default host/port:
# XALVION_LOCAL_API_ORIGIN=http://127.0.0.1:8000

# Optional: workspace UI on another origin still calling this API (rare).
# WORKSPACE_API_BASE_URL=https://your-api.up.railway.app

# Comma-separated extra CORS origins (custom domains, staging).
# ALLOWED_ORIGINS=https://app.example.com,https://staging.example.com

# Optional: full regex override for CORS (advanced).
# CORS_ORIGIN_REGEX=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=
# Optional overrides (defaults built from FRONTEND_URL / API_PUBLIC_ORIGIN):
# CHECKOUT_SUCCESS_URL=
# CHECKOUT_CANCEL_URL=
# STRIPE_CONNECT_REDIRECT_URI=

# --- Database (hosted: use Postgres; SQLite on Railway needs a volume — see README) ---
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/dbname
# STATE_STORE_DIR=/data

# --- Server ---
# PORT=8000
